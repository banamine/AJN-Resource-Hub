/**
 * UI Module - DOM manipulation and rendering
 * @module ui
 */

/**
 * Escape HTML special characters
 * @param {string} str - Input string
 * @returns {string}
 */
export function escapeHtml(str) {
    if (!str) return '';
    const replacements = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
    };
    return str.replace(/[&<>"']/g, char => replacements[char]);
}

/**
 * Get type badge HTML
 * @param {string} type - 'alex', 'warroom', or 'special'
 * @returns {string}
 */
export function getTypeBadge(type) {
    const badges = {
        alex: '<span class="badge-alex">🎙️ ALEX</span>',
        warroom: '<span class="badge-warroom">⚔️ WAR ROOM</span>',
        special: '<span class="badge-special">⭐ SPECIAL</span>'
    };
    return badges[type] || badges.alex;
}

/**
 * Render playlist
 * @param {Array} segments - Video segments
 * @param {number} currentIndex - Currently playing index
 * @param {HTMLElement} container - Playlist container
 * @param {Function} onSelect - Selection callback
 */
export function renderPlaylist(segments, currentIndex, container, onSelect) {
    if (!container) return;
    
    if (!segments || segments.length === 0) {
        container.innerHTML = '<div class="empty-playlist" style="text-align: center; padding: 2rem; color: #64748b;">No segments for this date</div>';
        return;
    }
    
    const html = segments.map((seg, idx) => {
        const typeBadge = getTypeBadge(seg.type);
        const hourDisplay = seg.hour ? `Hr${seg.hour}` : '';
        const isActive = idx === currentIndex;
        
        return `
            <div class="playlist-item ${isActive ? 'active' : ''}" data-index="${idx}">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
                    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
                        ${typeBadge}
                        ${hourDisplay ? `<span style="font-size: 0.7rem; color: #94a3b8;">${hourDisplay}</span>` : ''}
                        <span style="font-size: 0.65rem; color: #64748b;">${seg.displayDate}</span>
                    </div>
                    ${isActive ? '<span style="color: #10b981; font-size: 0.7rem;">▶ PLAYING</span>' : ''}
                </div>
                <div style="font-size: 0.75rem; color: #cbd5e1; margin-top: 0.25rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    ${escapeHtml(seg.title.substring(0, 70))}
                </div>
            </div>
        `;
    }).join('');
    
    container.innerHTML = html;
    
    // Attach click handlers
    const items = container.querySelectorAll('.playlist-item');
    items.forEach(item => {
        item.addEventListener('click', () => {
            const index = parseInt(item.dataset.index, 10);
            if (!isNaN(index) && onSelect) {
                onSelect(index);
            }
        });
    });
}

/**
 * Update status display
 * @param {HTMLElement} element - Status element
 * @param {string} message - Status message
 * @param {boolean} isError - Whether it's an error
 */
export function updateStatus(element, message, isError = false) {
    if (!element) return;
    element.innerHTML = message;
    if (isError) {
        element.style.color = '#ef4444';
    } else {
        element.style.color = '#94a3b8';
    }
}

/**
 * Show loading spinner
 * @param {HTMLElement} element - Target element
 */
export function showLoading(element) {
    if (element) {
        element.innerHTML = '<span class="loading-spinner"></span> Loading...';
    }
}

/**
 * Hide loading indicator
 * @param {HTMLElement} element - Target element
 * @param {string} message - Success message
 */
export function hideLoading(element, message) {
    if (element && message) {
        element.innerHTML = message;
    }
}
